server {
    listen 80;
    server_name localhost;

    # ========================
    # FRONTEND (Vite / React)
    # ========================
    location / {
        root /usr/share/nginx/html;
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    # ========================
    # STRAPI API
    # ========================
    location /api {
        proxy_pass http://strapi-back-end:1337;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ========================
    # STRAPI ADMIN
    # ========================
    location /admin {
        proxy_pass http://strapi-back-end:1337;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ========================
    # STRAPI UPLOADS (arquivos públicos)
    # ========================
    location /uploads {
        proxy_pass http://strapi-back-end:1337;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ========================
    # STRAPI MEDIA LIBRARY (UPLOAD POST)
    # ========================
    location /upload {
        proxy_pass http://strapi-back-end:1337;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        client_max_body_size 50M;
    }

    # ========================
    # I18N
    # ========================
    location /i18n {
        proxy_pass http://strapi-back-end:1337;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
    }

    # ========================
    # ADMIN PLUGINS (todos)
    # ========================
    location ~ ^/(content-manager|content-type-builder|users-permissions|email) {
        proxy_pass http://strapi-back-end:1337;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}